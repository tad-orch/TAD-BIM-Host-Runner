{
  "compilerOptions": {
    "target": "ES2023",
    "lib": [
      "ES2023"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo.node",
    "types": [
      "node"
    ]
  },
  "include": [
    "vite.config.ts",
    "tailwind.config.ts"
  ]
}
