# Backend bind address and port
HOST=127.0.0.1
PORT=8080

# Data storage
DATA_DIR=./data
# SQLITE_DB_PATH=./data/app.db

# Request and polling timing
BRIDGE_REQUEST_TIMEOUT_MS=10000
POLL_INTERVAL_MS=2000
POLL_TIMEOUT_MS=120000

# Replace the example baseUrl and bearer placeholder with your own bridge details.
HOSTS_JSON=[{"id":"tad-bim-01","baseUrl":"http://127.0.0.1:3001","machineType":"revit-bridge","capabilities":["revit","acc"],"enabledTools":["revit_ping","revit_create_wall","revit_session_status","revit_launch","revit_open_cloud_model","revit_list_3d_views","revit_export_nwc"],"headers":{"authorization":"Bearer REPLACE_WITH_BRIDGE_TOKEN"}}]

# Optional APS discovery credentials for ACC/Docs metadata lookup
# APS_BASE_URL=https://developer.api.autodesk.com
# APS_CLIENT_ID=REPLACE_WITH_APS_CLIENT_ID
# APS_CLIENT_SECRET=REPLACE_WITH_APS_CLIENT_SECRET
# APS_SCOPES=data:read
# APS_ACCOUNT_ID=REPLACE_WITH_ACC_HUB_OR_ACCOUNT_ID
# APS_USER_ID=REPLACE_WITH_OPTIONAL_CONTEXT_USER_ID
# APS_TOKEN_STORAGE_PATH=./data/auth/aps-token.json
# APS_CALLBACK_URL=http://127.0.0.1:8080/aps/callback
# APS_CALLBACK_URL is optional and reserved for future three-legged flows. It is not required for this discovery MVP.

# Optional local model settings
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
